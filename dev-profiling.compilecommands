# Profiling-only HotSpot CompileCommand file. Loaded via JVM
# argument -XX:CompileCommandFile=dev-profiling.compilecommands (added to
# build.gradle's runs.client block). Disables inlining of every method that
# OverloadedPowerSupplyLogic#tickNormal calls directly so that a spark
# sampler report can break out their individual self-time. Without this,
# JIT inlines them all into tickNormal and their cost is invisibly merged
# into tickNormal.self.
#
# WARNING: Do NOT ship this. It only exists for development profiling, and
# disabling inlining will measurably slow the very methods you're trying
# to measure (~5-15 ns of method-dispatch overhead each, multiplied by 64
# targets per tick).
#
# Format: <command> <class> <method> [<signature>]
# Method names are matched without signature when no signature given.

# --- BufferedMEStorage hot path -------------------------------------------------
dontinline com/moakiee/ae2lt/logic/energy/BufferedMEStorage beginMemoryBatch
dontinline com/moakiee/ae2lt/logic/energy/BufferedMEStorage endBatch
dontinline com/moakiee/ae2lt/logic/energy/BufferedMEStorage extract
dontinline com/moakiee/ae2lt/logic/energy/BufferedMEStorage insert
dontinline com/moakiee/ae2lt/logic/energy/BufferedMEStorage extractFromBuffer
dontinline com/moakiee/ae2lt/logic/energy/BufferedMEStorage extractThroughCell
dontinline com/moakiee/ae2lt/logic/energy/BufferedMEStorage resolveCell
dontinline com/moakiee/ae2lt/logic/energy/BufferedMEStorage recordConsumption
dontinline com/moakiee/ae2lt/logic/energy/BufferedMEStorage recordReturn

# --- AppFlux bridge / access (cap-call layer) ----------------------------------
dontinline com/moakiee/ae2lt/logic/energy/AppFluxBridge simulateTarget
dontinline com/moakiee/ae2lt/logic/energy/AppFluxBridge sendToTargetKnownDemand
dontinline com/moakiee/ae2lt/logic/energy/AppFluxAccess simulateTarget
dontinline com/moakiee/ae2lt/logic/energy/AppFluxAccess sendToTargetKnownDemand

# --- OverloadedPowerSupplyLogic helpers reachable from tickNormal --------------
dontinline com/moakiee/ae2lt/logic/OverloadedPowerSupplyLogic pollNormalWheel
dontinline com/moakiee/ae2lt/logic/OverloadedPowerSupplyLogic ensureNormalBatchCapacity
dontinline com/moakiee/ae2lt/logic/OverloadedPowerSupplyLogic adjustAndScheduleNormalEntry
dontinline com/moakiee/ae2lt/logic/OverloadedPowerSupplyLogic requeueNormalEntriesSoon
dontinline com/moakiee/ae2lt/logic/OverloadedPowerSupplyLogic scheduleNormalEntry
dontinline com/moakiee/ae2lt/logic/OverloadedPowerSupplyLogic rebuildNormalWheel
dontinline com/moakiee/ae2lt/logic/OverloadedPowerSupplyLogic setStatus
dontinline com/moakiee/ae2lt/logic/OverloadedPowerSupplyLogic updateIdleFailureStatus

# --- BlockEnergyTargetCache.resolve (inner class of OverloadedPowerSupplyLogic) -
dontinline com/moakiee/ae2lt/logic/OverloadedPowerSupplyLogic$BlockEnergyTargetCache resolve
