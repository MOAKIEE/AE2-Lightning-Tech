{
  "multipart": [
    {
      "when": {
        "half": "lower",
        "facing": "north"
      },
      "apply": {
        "model": "ae2lt:block/tesla_coil"
      }
    },
    {
      "when": {
        "half": "lower",
        "facing": "east"
      },
      "apply": {
        "model": "ae2lt:block/tesla_coil",
        "y": 90
      }
    },
    {
      "when": {
        "half": "lower",
        "facing": "south"
      },
      "apply": {
        "model": "ae2lt:block/tesla_coil",
        "y": 180
      }
    },
    {
      "when": {
        "half": "lower",
        "facing": "west"
      },
      "apply": {
        "model": "ae2lt:block/tesla_coil",
        "y": 270
      }
    },
    {
      "when": {
        "half": "lower",
        "facing": "north",
        "working": "true"
      },
      "apply": {
        "model": "ae2lt:block/tesla_coil_work"
      }
    },
    {
      "when": {
        "half": "lower",
        "facing": "east",
        "working": "true"
      },
      "apply": {
        "model": "ae2lt:block/tesla_coil_work",
        "y": 90
      }
    },
    {
      "when": {
        "half": "lower",
        "facing": "south",
        "working": "true"
      },
      "apply": {
        "model": "ae2lt:block/tesla_coil_work",
        "y": 180
      }
    },
    {
      "when": {
        "half": "lower",
        "facing": "west",
        "working": "true"
      },
      "apply": {
        "model": "ae2lt:block/tesla_coil_work",
        "y": 270
      }
    }
  ]
}
